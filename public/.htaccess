<IfModule mod_rewrite.c>
    RewriteEngine On

    # Send all requests to the single front controller.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Never expose sensitive dotfiles.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
